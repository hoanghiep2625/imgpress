# Server settings
PORT=3000
SERVER_TIMEOUT_MS=300000
KEEP_ALIVE_TIMEOUT_MS=360000
HEADERS_TIMEOUT_MS=361000

# Image validation limits
MAX_IMAGE_SIDE_PX=20000
MAX_IMAGE_MEGAPIXELS=200
MAX_FILE_SIZE_MB=50
MAX_FILES=20

# Compression defaults
DEFAULT_QUALITY=80
DEFAULT_WIDTH=1600
COMPRESS_TIMEOUT_MS=300000

# Quality constraints
MAX_QUALITY_NO_ALPHA=85
MAX_QUALITY_WITH_ALPHA=90

# Dither algorithm tuning
DITHER_MAX=0.7
DITHER_MIN=0.3

# Sharp library settings
SHARP_CONCURRENCY=0
